{
  "name": "debug-drawer-monorepo",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "pnpm --filter debug-drawer build && pnpm --filter docs build",
    "build:lib": "pnpm --filter debug-drawer build",
    "build:docs": "pnpm --filter docs build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "changeset": "changeset",
    "version-package": "changeset version",
    "release": "pnpm --filter debug-drawer release"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "turbo": "^2.9.3",
    "typescript": "~5.7.2"
  },
  "packageManager": "pnpm@10.0.0"
}
