{
  "name": "@withgus/debug",
  "version": "1.2.0",
  "description": "A debug drawer for switching MSW mock scenarios per page at runtime",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./css": {
      "require": "./dist/debug.css",
      "import": "./dist/debug.css"
    }
  },
  "author": {
    "name": "Gustavo S Souza",
    "email": "kyoro_souza@hotmail.com",
    "url": "https://github.com/Futhememe-official"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --declaration --outDir dist",
    "typecheck": "tsc --noEmit",
    "dev": "vite build --watch",
    "release": "pnpm build && changeset publish"
  },
  "peerDependencies": {
    "msw": ">=2.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "vaul": ">=1.0.0",
    "zustand": ">=4.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-dts": "^4.3.0"
  },
  "keywords": [
    "msw",
    "mock",
    "debug",
    "drawer",
    "testing",
    "react",
    "vaul"
  ],
  "license": "MIT"
}
